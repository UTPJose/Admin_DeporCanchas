# Copia este archivo a .env y completa los valores reales. NO subir .env al repo.

# Supabase (misma instancia que el cliente)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth admin (bcrypt + JWT propio sobre usuarios/roles)
# Generar con: openssl rand -base64 32
ADMIN_JWT_SECRET=

# Environment
NEXT_ENV=development
